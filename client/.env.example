# API base path. Empty/relative => served via the nginx /api reverse-proxy.
NEXT_PUBLIC_API_BASE_URL=/api

# Google Analytics 4 measurement id (e.g. G-XXXXXXXXXX). Leave empty to disable.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google AdSense — set both to serve real ads (Consent Mode v2 applies).
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT=

# Public site URL (canonical / OG / sitemap)
NEXT_PUBLIC_SITE_URL=

# Optional Sentry DSN for client error reporting
NEXT_PUBLIC_SENTRY_DSN=
