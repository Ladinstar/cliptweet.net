# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=twitter_downloader

# Optional Redis (shared cache + rate-limit across instances). Empty = in-memory.
REDIS_URL=

# Admin account (seeded on first boot)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# CORS — comma-separated allowed origins (leave empty in dev to reflect origin)
CORS_ORIGINS=

# Download tuning
DOWNLOAD_CONCURRENCY=2
DOWNLOAD_TIMEOUT_MS=30000
AUDIO_TIMEOUT_MS=90000
FORMATS_CACHE_TTL_MS=600000
MAX_MEDIA_BYTES=314572800
MEDIA_FETCH_TIMEOUT_MS=20000
# Optional Netscape cookies.txt to authenticate yt-dlp. Required to fetch
# age-restricted / login-gated videos (mostly YouTube); also hardens extraction
# when a platform blocks guest tokens. Path is relative to the server dir.
#   1. Install a "Get cookies.txt LOCALLY" browser extension.
#   2. Log into a THROWAWAY account (never your personal one — it can get banned).
#   3. Export cookies.txt and drop it in server/, then set the line below.
# The file is gitignored (cookies.txt). Leave empty for guest mode.
YT_DLP_COOKIES=
# Self-update yt-dlp on boot (set to "false" to pin the build-time binary)
YT_DLP_AUTO_UPDATE=true

# Operational alerting — Slack webhook fired when extraction failure rate spikes
ALERT_SLACK_WEBHOOK=
ALERT_WINDOW_SIZE=50
ALERT_MIN_SAMPLES=10
ALERT_ERROR_RATE=0.5
ALERT_COOLDOWN_MS=1800000
