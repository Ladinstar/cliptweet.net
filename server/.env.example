# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=twitter_downloader

# Optional Redis (shared cache + rate-limit across instances). Empty = in-memory.
REDIS_URL=

# Admin account (seeded on first boot)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# CORS — comma-separated allowed origins (leave empty in dev to reflect origin)
CORS_ORIGINS=

# Download tuning
DOWNLOAD_CONCURRENCY=2
DOWNLOAD_TIMEOUT_MS=30000
AUDIO_TIMEOUT_MS=90000
FORMATS_CACHE_TTL_MS=600000
MAX_MEDIA_BYTES=314572800
# Optional Netscape cookies.txt to harden extraction when X blocks guest tokens
YT_DLP_COOKIES=
